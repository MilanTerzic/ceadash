# Public client configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side Supabase cache/database access
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ENTSO-E Transparency Platform
# CEA legacy fetchers use ENTSOE_SECURITY_TOKEN; ported Power Pulse fetchers use ENTSOE_API_TOKEN.
# Set both to the same Transparency Platform token unless you intentionally separate them.
ENTSOE_SECURITY_TOKEN=
ENTSOE_API_TOKEN=

# Optional provider integrations
VISUAL_CROSSING_API_KEY=
FIRECRAWL_API_KEY=
LOVABLE_API_KEY=

# Optional futures snapshot provider
EEX_DATASOURCE_API_URL=
EEX_DATASOURCE_ACCESS_TOKEN=
FUTURES_PUBLIC_SNAPSHOT_MODE=true
