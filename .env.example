# Public client configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side Supabase cache/database access
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ENTSO-E Transparency Platform
# Server-side fetchers accept any one of these aliases. Prefer ENTSOE_SECURITY_TOKEN
# for new deployments, or keep the variable name already configured by your host.
ENTSOE_SECURITY_TOKEN=
ENTSOE_API_TOKEN=
ENTSOE_API_KEY=

# Optional provider integrations
VISUAL_CROSSING_API_KEY=
FIRECRAWL_API_KEY=
LOVABLE_API_KEY=

# Optional futures snapshot provider
EEX_DATASOURCE_API_URL=
EEX_DATASOURCE_ACCESS_TOKEN=
FUTURES_PUBLIC_SNAPSHOT_MODE=true
